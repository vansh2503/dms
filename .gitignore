# Hyundai DMS - Git Ignore File

# ===== FRONTEND =====

# Dependencies
frontend/node_modules/
frontend/.pnp
frontend/.pnp.js

# Testing
frontend/coverage/

# Production
frontend/build/
frontend/dist/

# Environment variables
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/lerna-debug.log*

# Editor directories and files
frontend/.vscode/*
!frontend/.vscode/extensions.json
frontend/.idea
frontend/.DS_Store
frontend/*.suo
frontend/*.ntvs*
frontend/*.njsproj
frontend/*.sln
frontend/*.sw?

# ===== ROOT LEVEL IDE FILES =====
.idea/
.vscode/

# ===== BACKEND =====

# Compiled class files
backend/target/
backend/!.mvn/wrapper/maven-wrapper.jar
backend/!**/src/main/**/target/
backend/!**/src/test/**/target/

# Maven local settings (use user's ~/.m2/settings.xml instead)
backend/.m2/

# Log files
backend/*.log
backend/logs/

# BlueJ files
backend/*.ctxt

# Mobile Tools for Java (J2ME)
backend/.mtj.tmp/

# Package Files
backend/*.jar
backend/*.war
backend/*.nar
backend/*.ear
backend/*.zip
backend/*.tar.gz
backend/*.rar

# Virtual machine crash logs
backend/hs_err_pid*
backend/replay_pid*

# Eclipse
backend/.apt_generated
backend/.classpath
backend/.factorypath
backend/.project
backend/.settings
backend/.springBeans
backend/.sts4-cache

# IntelliJ IDEA
backend/.idea
backend/*.iws
backend/*.iml
backend/*.ipr

# NetBeans
backend/nbproject/private/
backend/nbbuild/
backend/dist/
backend/nbdist/
backend/.nb-gradle/
backend/build/
backend/!**/src/main/**/build/
backend/!**/src/test/**/build/

# VS Code
backend/.vscode/

# Mac
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ===== DATABASE =====
*.db
*.sqlite
*.sqlite3

# ===== ENVIRONMENT FILES =====
.env
.env.local
.env.*.local

# ===== SENSITIVE DATA =====
**/application-local.properties
**/application-dev.properties
**/*-secret.yml
**/*-secret.yaml
**/secrets/

# ===== TEMPORARY FILES =====
*.tmp
*.temp
*.swp
*.swo
*~
~$*

# ===== DOCUMENTATION BUILD =====
docs/_build/
site/

# ===== MISC =====
.cache/
*.pid
*.seed
*.pid.lock

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
